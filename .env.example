# ResQ.AI Backend — Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Flask settings
FLASK_DEBUG=false
FLASK_ENV=production

# CORS — comma-separated list of allowed origins (* = allow all)
# For production, set this to your exact Vercel URL:
# ALLOWED_ORIGINS=https://resqai-frontend.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=*

# Port (set automatically by Render/Heroku — leave blank for local dev)
# PORT=5000
